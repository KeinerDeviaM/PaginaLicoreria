:root {
  --bg: #0f0f10;
  --panel: #18181b;
  --panel-2: #212124;
  --border: #2b2b31;
  --text: #f4f4f5;
  --muted: #b8b8c2;
  --gold: #d4af37;
  --wine: #722f37;
  --success: #16a34a;
  --danger: #dc2626;
  --warning: #d97706;
  --info: #2563eb;
}
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: Inter, system-ui, Arial, sans-serif;
  background: radial-gradient(circle at top right, rgba(212,175,55,.08), transparent 25%), var(--bg);
  color: var(--text);
}
a { color: inherit; text-decoration: none; }
button, input, select, textarea {
  font: inherit;
}
button {
  cursor: pointer;
}
.container {
  width: min(1200px, calc(100% - 32px));
  margin: 0 auto;
}
.page {
  padding: 24px 0 32px;
}
.card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 16px;
  box-shadow: 0 10px 30px rgba(0,0,0,.22);
}
.grid {
  display: grid;
  gap: 16px;
}
.grid-2 { grid-template-columns: repeat(2, minmax(0,1fr)); }
.grid-3 { grid-template-columns: repeat(3, minmax(0,1fr)); }
.grid-4 { grid-template-columns: repeat(4, minmax(0,1fr)); }
@media (max-width: 900px) {
  .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
}
h1,h2,h3,h4,p { margin-top: 0; }
input, select, textarea {
  width: 100%;
  background: var(--panel-2);
  border: 1px solid var(--border);
  color: var(--text);
  border-radius: 12px;
  padding: 12px;
}
label {
  display: block;
  margin-bottom: 8px;
  color: var(--muted);
  font-size: 14px;
}
.form-group { margin-bottom: 14px; }
.btn {
  border: none;
  background: var(--panel-2);
  color: var(--text);
  padding: 11px 14px;
  border-radius: 12px;
  transition: .2s ease;
}
.btn:hover { filter: brightness(1.08); }
.btn-primary { background: var(--gold); color: #121212; font-weight: 700; }
.btn-danger { background: var(--danger); color: white; }
.btn-success { background: var(--success); color: white; }
.btn-outline { border: 1px solid var(--border); background: transparent; }
.btn-wine { background: var(--wine); color: white; }
.stack { display: flex; gap: 12px; flex-wrap: wrap; }
.nav {
  position: sticky;
  top: 0;
  z-index: 30;
  background: rgba(15,15,16,.94);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  width: min(1300px, calc(100% - 24px));
  margin: 0 auto;
  min-height: 70px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.brand { display:flex; align-items:center; gap:10px; font-weight:700; }
.brand-badge {
  display:grid; place-items:center;
  width: 38px; height: 38px; border-radius: 12px;
  background: linear-gradient(135deg, var(--gold), #8b6b1b);
  color: #131313;
}
.nav-links { display:flex; align-items:center; gap:14px; flex-wrap: wrap; }
.nav-link { color: var(--muted); font-size: 14px; }
.nav-link.active, .nav-link:hover { color: var(--gold); }
.kpi {
  padding: 18px; border-radius: 18px; background: var(--panel);
  border: 1px solid var(--border);
}
.kpi .value { font-size: 32px; font-weight: 800; }
.kpi .label { color: var(--muted); font-size: 14px; }
.table-wrap { overflow:auto; }
table { width: 100%; border-collapse: collapse; }
th, td {
  text-align:left;
  padding: 12px 10px;
  border-bottom: 1px solid var(--border);
}
th { color: var(--muted); font-size: 13px; }
.badge {
  display:inline-block; padding:6px 10px; border-radius:999px;
  font-size:12px; font-weight:700;
}
.badge.gold { background: rgba(212,175,55,.14); color: var(--gold); }
.badge.success { background: rgba(22,163,74,.14); color: #7ef0a0; }
.badge.danger { background: rgba(220,38,38,.14); color: #ff9a9a; }
.badge.warning { background: rgba(217,119,6,.14); color: #ffc56b; }
.badge.info { background: rgba(37,99,235,.14); color: #9ec0ff; }
.hero {
  padding: 56px 0 32px;
}
.hero h1 { font-size: 52px; line-height: 1.03; }
.hero p { color: var(--muted); max-width: 700px; }
.product-grid { display:grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap:16px; }
@media (max-width: 1000px) { .product-grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
@media (max-width: 640px) { .product-grid { grid-template-columns: 1fr; } .hero h1 { font-size: 36px; } }
.product-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 18px;
  overflow: hidden;
}
.product-image {
  height: 220px;
  display:grid;
  place-items:center;
  background: linear-gradient(180deg, #1d1d21, #111113);
  color: var(--gold);
  font-size: 40px;
  font-weight: 800;
}
.product-body { padding: 16px; }
.small { color: var(--muted); font-size: 13px; }
.layout {
  display:grid;
  grid-template-columns: 260px 1fr;
  min-height: calc(100vh - 70px);
}
@media (max-width: 900px) { .layout { grid-template-columns: 1fr; } }
.sidebar {
  background: var(--panel);
  border-right: 1px solid var(--border);
  padding: 20px 14px;
}
.sidebar .menu { display:flex; flex-direction: column; gap:8px; }
.sidebar .menu a {
  padding: 11px 12px;
  border-radius: 12px;
  color: var(--muted);
}
.sidebar .menu a.active, .sidebar .menu a:hover {
  background: rgba(212,175,55,.1);
  color: var(--gold);
}
.main { padding: 20px; }
.notice {
  border-radius: 14px;
  padding: 12px 14px;
  margin-bottom: 14px;
}
.notice.error { background: rgba(220,38,38,.14); color: #ff9a9a; }
.notice.success { background: rgba(22,163,74,.14); color: #7ef0a0; }
.notice.info { background: rgba(37,99,235,.14); color: #9ec0ff; }
.notice.warning { background: rgba(217,119,6,.14); color: #ffc56b; }
.split {
  display:grid;
  grid-template-columns: 1.2fr .8fr;
  gap: 16px;
}
@media (max-width: 960px) { .split { grid-template-columns: 1fr; } }
hr.sep {
  border: none;
  border-top: 1px solid var(--border);
  margin: 16px 0;
}
.bar-list { display: grid; gap: 12px; margin-top: 12px; }
.bar-row { display: grid; gap: 6px; }
.bar-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
.bar-track { width: 100%; height: 10px; background: rgba(255,255,255,0.08); border-radius: 999px; overflow: hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg, var(--gold), #f5d97b); border-radius: 999px; }
.invoice-sheet { background: #fff; color: #111; border-radius: 18px; padding: 24px; }
.invoice-header { display: flex; justify-content: space-between; gap: 16px; border-bottom: 2px solid #e7e7e7; padding-bottom: 14px; }
.invoice-totals { margin-top: 18px; display: grid; gap: 6px; justify-content: end; }
@media print {
  body { background: #fff; }
  .nav, .sidebar, .btn, .notice, .no-print { display: none !important; }
  .main, .page, .container { padding: 0 !important; width: 100% !important; margin: 0 !important; }
  .card { box-shadow: none !important; border: none !important; background: transparent !important; }
  .printable-invoice-wrapper { grid-template-columns: 1fr !important; }
  .invoice-sheet { box-shadow: none; border: none; }
}
